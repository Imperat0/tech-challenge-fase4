# Manter arquivos de configuração e scripts dentro dos datasets
!data/datasets/**/*.py
!data/datasets/**/*.yaml
!data/datasets/**/*.json
!data/datasets/**/*.csv

# Modelos grandes
models/yolov8/weights/*.pt
*.pt
notebooks/runs/

